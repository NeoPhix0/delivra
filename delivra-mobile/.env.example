# ==========================================
# Delivra Mobile - Environment Variables
# ==========================================

# API Configuration
# URL de l'API Delivra backend

# Pour le développement local sur Android Emulator:
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api

# Pour le développement local sur iOS Simulator:
# EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Pour le développement avec un vrai device sur le même réseau:
# EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:3000/api
# Remplacer YOUR_LOCAL_IP par l'adresse IP de votre machine (ex: 192.168.1.100)

# Note: EXPO_OS est automatiquement défini par Expo (ios, android, web)
